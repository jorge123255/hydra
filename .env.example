# Discord (optional — remove if not using)
DISCORD_TOKEN=your_discord_bot_token
DISCORD_ACCESS_ROLE=Hydra
DISCORD_DENY_ROLE=no-hydra

# Telegram (optional — remove if not using)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Comma-separated list of allowed user IDs or usernames
TELEGRAM_ALLOW_FROM=123456789,yourusername

# Working directory for OpenCode coding sessions
HYDRA_WORKDIR=/path/to/your/projects
