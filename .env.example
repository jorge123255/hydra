# ── Discord ──────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
DISCORD_ACCESS_ROLE=Hydra
DISCORD_DENY_ROLE=no-hydra

# ── Telegram ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Comma-separated allowed user IDs or usernames
TELEGRAM_ALLOW_FROM=123456789,yourusername

# ── Slack ────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
# Socket Mode (recommended — no public URL needed)
SLACK_APP_TOKEN=xapp-your-app-token
# OR HTTP webhook mode (alternative to socket mode)
# SLACK_SIGNING_SECRET=your_signing_secret
# SLACK_PORT=3000
# Comma-separated allowed Slack user IDs
# SLACK_ALLOW_FROM=U012AB3CD,U098ZY7WX

# ── OpenCode ─────────────────────────────────────────────────────
# Working directory for coding sessions
HYDRA_WORKDIR=/path/to/your/projects
# Enable per-thread git worktrees (isolated branches per conversation)
HYDRA_WORKTREES=false
